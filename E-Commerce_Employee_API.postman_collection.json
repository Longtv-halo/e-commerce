{
  "info": {
    "_postman_id": "e-commerce-api-1",
    "name": "E-Commerce Employee API",
    "description": "Complete collection for Employee CRUD operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Employee",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Response has success=true', function () {",
              "    pm.expect(jsonData.success).to.eql(true);",
              "});",
              "",
              "// Save employee ID for next requests",
              "pm.globals.set('employee_id', jsonData.data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"empName\": \"John Doe\",\n    \"empEmail\": \"john.doe@example.com\",\n    \"empDepartment\": \"Engineering\",\n    \"page\": 0,\n    \"size\": 10,\n    \"sortBy\": \"id\",\n    \"sortDir\": \"asc\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employee/create",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employee", "create"]
        }
      }
    },
    {
      "name": "2. Get All Employees",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"empName\": \"x\",\n    \"empEmail\": \"x@x.com\",\n    \"page\": 0,\n    \"size\": 10,\n    \"sortBy\": \"name\",\n    \"sortDir\": \"asc\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employee/list",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employee", "list"]
        }
      }
    },
    {
      "name": "3. Search Employees",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"empName\": \"John\",\n    \"empEmail\": \"x@x.com\",\n    \"page\": 0,\n    \"size\": 10,\n    \"sortBy\": \"name\",\n    \"sortDir\": \"asc\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employee/search",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employee", "search"]
        }
      }
    },
    {
      "name": "4. Update Employee",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"empName\": \"John Updated\",\n    \"empEmail\": \"john.updated@example.com\",\n    \"empDepartment\": \"HR\",\n    \"page\": 0,\n    \"size\": 10\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employee/{{employee_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employee", "{{employee_id}}"]
        }
      }
    },
    {
      "name": "5. Delete Employee",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employee/{{employee_id}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employee", "{{employee_id}}"]
        }
      }
    },
    {
      "name": "TEST - Validation: Missing Name",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Response has success=false', function () {",
              "    pm.expect(jsonData.success).to.eql(false);",
              "});",
              "",
              "pm.test('Has empName error message', function () {",
              "    pm.expect(jsonData.data.empName).to.include('required');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"empName\": \"\",\n    \"empEmail\": \"john@example.com\",\n    \"empDepartment\": \"Engineering\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employee/create",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employee", "create"]
        }
      }
    },
