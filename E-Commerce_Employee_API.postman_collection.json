          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"empName\": \"x\",\n    \"empEmail\": \"x@x.com\",\n    \"page\": -1,\n    \"size\": 10,\n    \"sortBy\": \"name\",\n    \"sortDir\": \"asc\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employee/list",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employee", "list"]
        }
      }
    },
    {
      "name": "TEST - Validation: Size > 100",
      "request": {
