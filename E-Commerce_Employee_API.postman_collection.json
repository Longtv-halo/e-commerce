      }
    },
    {
      "name": "TEST - 404: Update Non-existent Employee",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Response has success=false', function () {",
              "    pm.expect(jsonData.success).to.eql(false);",
              "});",
              "",
              "pm.test('Code is 404', function () {",
              "    pm.expect(jsonData.code).to.eql('404');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"empName\": \"John\",\n    \"empEmail\": \"john@example.com\",\n    \"empDepartment\": \"HR\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employee/9999",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employee", "9999"]
        }
      }
    },
    {
      "name": "TEST - 404: Delete Non-existent Employee",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employee/9999",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employee", "9999"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "employee_id",
      "value": "",
      "type": "string"
    }
  ]
}

