            "url": "{{baseUrl}}/api/employee/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empName\": \"Le Thi Mai\",\n  \"empEmail\": \"le.thi.mai@company.vn\",\n  \"departmentId\": 2\n}"
            }
          }
        },
        {
          "name": "Create — Pham Quoc Bao (Marketing)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employee/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empName\": \"Pham Quoc Bao\",\n  \"empEmail\": \"pham.quoc.bao@company.vn\",\n  \"departmentId\": 2\n}"
            }
          }
        },
        {
          "name": "Create — Vo Thi Kim Anh (HR)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employee/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empName\": \"Vo Thi Kim Anh\",\n  \"empEmail\": \"vo.thi.kim.anh@company.vn\",\n  \"departmentId\": 3\n}"
            }
          }
        },
        {
          "name": "List All Employees (page 0)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employee/list",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"page\": 0,\n  \"size\": 10,\n  \"sortBy\": \"id\",\n  \"sortDir\": \"asc\"\n}"
            }
          }
        },
        {
          "name": "Search Employee — 'Nguyen'",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employee/search",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empName\": \"Nguyen\",\n  \"page\": 0,\n  \"size\": 10,\n  \"sortBy\": \"empName\",\n  \"sortDir\": \"asc\"\n}"
            }
          }
        },
        {
          "name": "Get Employee By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/employee/{{employeeId}}"
          }
        },
        {
          "name": "Update Employee — Nguyen Hoang Nam",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
