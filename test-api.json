            "body": {
              "mode": "raw",
              "raw": "{\n  \"empName\": \"Nguyen Hoang Nam (Senior)\",\n  \"empEmail\": \"nguyen.hoang.nam@company.vn\",\n  \"departmentId\": 1\n}"
            }
          }
        }
      ]
    },

    {
      "name": "4. RBAC — Role & Permission",
      "item": [
        {
          "name": "List All Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/role"
          }
        },
        {
          "name": "List All Permissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/permission"
          }
        },
        {
          "name": "Create Role — ROLE_REPORTER",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/role/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"ROLE_REPORTER\",\n  \"description\": \"Chi xem bao cao, khong chinh sua\",\n  \"permissionIds\": [1, 4]\n}"
            }
          }
        },
        {
          "name": "Assign Permissions to Role (id=2 ROLE_MANAGER)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/role/2/permissions",
            "body": {
              "mode": "raw",
              "raw": "[1, 2, 4, 5]"
            }
          }
        }
      ]
    },

    {
      "name": "5. User Management",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/user/me"
          }
        },
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/user?page=0&size=10&sortBy=id&sortDir=asc",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sortBy", "value": "id" },
                { "key": "sortDir", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "Assign ROLE_MANAGER to User (id=2)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/user/2/roles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleIds\": [2]\n}"
            }
          }
        },
        {
          "name": "Toggle User Status — Lock (id=3)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/user/3/status"
          }
        }
      ]
    },

    {
      "name": "6. Error Cases",
      "item": [
        {
          "name": "[400] Create Employee — Missing empName",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employee/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empEmail\": \"test@company.vn\",\n  \"departmentId\": 1\n}"
            }
          }
        },
        {
          "name": "[400] Create Employee — Invalid Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employee/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empName\": \"Test User\",\n  \"empEmail\": \"not-an-email\",\n  \"departmentId\": 1\n}"
            }
          }
        },
        {
          "name": "[400] Create Employee — Department Not Found",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employee/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empName\": \"Test User\",\n  \"empEmail\": \"test@company.vn\",\n  \"departmentId\": 9999\n}"
            }
          }
        },
        {
          "name": "[404] Get Employee — Not Found",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/employee/9999"
          }
        },
        {
          "name": "[403] Access Role API — No Permission (login as nguyenvanan first)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/role"
          }
        },
        {
          "name": "[401] No Token",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/employee/1"
          }
        }
      ]
    }

  ]
