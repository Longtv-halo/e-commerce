{
  "info": {
    "name": "E-Commerce API — Full Test Suite",
    "description": "Test đầy đủ flow: Auth → Department → Employee → RBAC Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "departmentId", "value": "" },
    { "key": "employeeId", "value": "" }
  ],
  "item": [

    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login — Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.results && res.results.token) {",
                  "    pm.collectionVariables.set('token', res.results.token);",
                  "    console.log('Token saved:', res.results.token.substring(0, 30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Register — New User (Nguyen Van An)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van An\",\n  \"username\": \"nguyenvanan\",\n  \"password\": \"pass123456\"\n}"
            }
          }
        },
        {
          "name": "Register — Manager (Tran Thi Bich)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tran Thi Bich\",\n  \"username\": \"tranthbich\",\n  \"password\": \"pass123456\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "2. Department",
      "item": [
        {
          "name": "Create — Engineering",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.results && res.results.id) {",
                  "    pm.collectionVariables.set('departmentId', res.results.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/department/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Engineering\",\n  \"empEmail\": \"le.minh.tuan@company.vn\",\n  \"empName\": \"Le Minh Tuan\",\n  \"isOwner\": true\n}"
            }
          }
        },
        {
          "name": "Create — Marketing",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/department/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Marketing\",\n  \"empEmail\": \"pham.thu.huong@company.vn\",\n  \"empName\": \"Pham Thu Huong\",\n  \"isOwner\": true\n}"
            }
          }
        },
        {
          "name": "Create — Human Resources",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/department/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Human Resources\",\n  \"empEmail\": \"nguyen.thi.lan@company.vn\",\n  \"empName\": \"Nguyen Thi Lan\",\n  \"isOwner\": true\n}"
            }
          }
        },
        {
          "name": "List All Departments",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/department/list",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"page\": 0,\n  \"size\": 10,\n  \"sortBy\": \"id\",\n  \"sortDir\": \"asc\"\n}"
            }
          }
        },
        {
          "name": "Search Department — 'Eng'",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/department/search",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"departmentName\": \"Eng\",\n  \"page\": 0,\n  \"size\": 10,\n  \"sortBy\": \"id\",\n  \"sortDir\": \"asc\"\n}"
            }
          }
        },
        {
          "name": "Get Department By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/department/{{departmentId}}"
          }
        }
      ]
    },

    {
      "name": "3. Employee",
      "item": [
        {
          "name": "Create — Nguyen Hoang Nam (Engineering)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.results && res.results.id) {",
                  "    pm.collectionVariables.set('employeeId', res.results.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/employee/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empName\": \"Nguyen Hoang Nam\",\n  \"empEmail\": \"nguyen.hoang.nam@company.vn\",\n  \"departmentId\": 1\n}"
            }
          }
        },
        {
